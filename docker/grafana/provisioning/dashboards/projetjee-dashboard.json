{
  "title": "ProjetJee — Application Monitoring",
  "uid": "projetjee-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests / second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket[5m]))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes",
          "legendFormat": "{{area}} - {{id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Live Threads"
        }
      ]
    },
    {
      "id": 5,
      "title": "Application Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "up{job=\"projetjee-backend\"}",
          "legendFormat": "Backend UP"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "HTTP Errors (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status}} {{uri}}"
        }
      ]
    }
  ]
}
